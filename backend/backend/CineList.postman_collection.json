          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"detail\": \"Logged out successfully.\"\n}"
            }
          ]
        },
        {
          "name": "Get Current User (me)",
          "request": {
            "method": "GET",
